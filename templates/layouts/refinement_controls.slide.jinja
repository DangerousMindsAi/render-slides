---
layout: refinement_controls
editable_paths:
  - path: slides[*].layout
    operation: set_layout
    description: Sets the slide layout enum value.
    params: [layout]
    bounds: layout must be one of title, title_body, two_column, section, image_focus, quote, comparison
  - path: slides[*].slots.subtitle
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
  - path: slides[*].slots.left
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
  - path: slides[*].slots.right
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
  - path: slides[*].style.alignment
    operation: set_alignment
    description: Sets text alignment for the addressed style scope.
    params: [alignment]
    bounds: alignment must be one of left, center, right
  - path: slides[*].style.body.font_size
    operation: increase
    description: Increases font size by the requested step.
    params: [step]
    bounds: step must be a positive integer; resulting size 10..72
  - path: slides[*].style.body.font_size
    operation: decrease
    description: Decreases font size by the requested step.
    params: [step]
    bounds: step must be a positive integer; resulting size 10..72
---
<section class="slide layout-refinement-controls" data-layout="refinement_controls">
  <div data-slot="subtitle">{{ slide.slots.subtitle }}</div>
  <div data-slot="left">{{ slide.slots.left }}</div>
  <div data-slot="right">{{ slide.slots.right }}</div>
</section>
