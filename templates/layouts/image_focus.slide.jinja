---
layout: image_focus
editable_paths:
  - path: slides[*].slots.title
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
  - path: slides[*].slots.image
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
  - path: slides[*].slots.caption
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
---
<section class="slide layout-image-focus" data-layout="image_focus">
  <h1 data-slot="title">{{ slide.slots.title }}</h1>
  <figure>
    <img data-slot="image" src="{{ slide.slots.image }}" alt="" />
    <figcaption data-slot="caption">{{ slide.slots.caption }}</figcaption>
  </figure>
</section>
