---
layout: two_column
editable_paths:
  - path: slides[*].slots.title
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
  - path: slides[*].slots.left
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
  - path: slides[*].slots.right
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
---
<section class="slide layout-two-column" data-layout="two_column">
  <h1 data-slot="title">{{ slide.slots.title }}</h1>
  <div class="column-left" data-slot="left">{{ slide.slots.left }}</div>
  <div class="column-right" data-slot="right">{{ slide.slots.right }}</div>
</section>
