---
layout: quote
editable_paths:
  - path: slides[*].slots.quote
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
  - path: slides[*].slots.attribution
    operation: set_text
    description: Replaces text content for the selected slot.
    params: [text]
    bounds: text length must be <= 2000 characters
---
<section class="slide layout-quote" data-layout="quote">
  <blockquote data-slot="quote">{{ slide.slots.quote }}</blockquote>
  <cite data-slot="attribution">{{ slide.slots.attribution }}</cite>
</section>
